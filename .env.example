# Google AI Studio で発行したAPIキー（カード登録不要の無料枠）
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key-here

# 使用モデル（省略時は gemini-2.5-flash）
# GEMINI_MODEL=gemini-2.5-flash

# SQLiteの保存先（省略時はプロジェクト直下の lingoflow.db）
# TURSO_DATABASE_URL / TURSO_AUTH_TOKEN を設定した場合はそちらが優先される
# DB_PATH=lingoflow.db

# Turso（永続DB。Render無料枠のディスク揮発性を回避したい場合に設定）
# https://turso.tech でカード登録不要のアカウント作成 → データベース作成 → URL/トークン発行
# 両方とも未設定ならローカルのSQLiteファイル（DB_PATH）を使う
# TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token
